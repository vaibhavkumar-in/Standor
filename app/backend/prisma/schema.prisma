// FILE: apps/server/prisma/schema.prisma
// MongoDB provider via Prisma 5

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String
  password  String?
  avatar    String?
  googleId  String?  @unique
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  lastLogin DateTime @default(now())

  hostedSessions      Session[] @relation("HostedSessions")
  participantSessions Session[] @relation("ParticipantSessions")
}

enum Role {
  USER
  ADMIN
}

model Session {
  id         String        @id @default(auto()) @map("_id") @db.ObjectId
  roomId     String        @unique @default(cuid())
  problem    String
  difficulty Difficulty    @default(MEDIUM)
  status     SessionStatus @default(ACTIVE)

  hostId        String  @db.ObjectId
  host          User    @relation("HostedSessions", fields: [hostId], references: [id])
  participantId String? @db.ObjectId
  participant   User?   @relation("ParticipantSessions", fields: [participantId], references: [id])

  codeSnapshots CodeSnapshot[]
  aiAnalysis    AIAnalysis?

  startedAt DateTime  @default(now())
  endedAt   DateTime?
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum SessionStatus {
  ACTIVE
  COMPLETED
}

type CodeSnapshot {
  content   String
  language  String
  timestamp DateTime @default(now())
}

type AIAnalysis {
  timeComplexity  String
  spaceComplexity String
  correctness     Int
  bugs            String[]
  suggestions     String[]
  codeStyle       Int
  overallScore    Int
  summary         String
  tests           String[]
  analyzedAt      DateTime @default(now())
}
