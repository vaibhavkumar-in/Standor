# =============================================================
# Standor — Root Environment Configuration
# Copy to .env and fill in values. Never commit .env.
# =============================================================

# ---- Server ----
PORT=4000
NODE_ENV=development

# ---- Database (MongoDB Atlas free tier) ----
# Get at: mongodb.com/cloud/atlas → Create free M0 cluster
DATABASE_URL="mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/standor?retryWrites=true&w=majority"

# ---- Auth ----
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<your-64-char-hex-secret>
JWT_EXPIRES_IN=7d

# ---- Google OAuth ----
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# ---- Frontend URL (CORS) ----
CLIENT_URL=http://localhost:3000

# ---- AI Analysis (OpenRouter — free credits on signup) ----
# openrouter.ai → API Keys
OPENROUTER_API_KEY=<your-openrouter-api-key>
OPENROUTER_MODEL=deepseek/deepseek-coder

# ---- Code Execution (Piston — public API, no key needed) ----
PISTON_API_URL=https://emkc.org/api/v2/piston

# ---- Email (Brevo SMTP — 300 emails/day free) ----
# brevo.com → SMTP & API → SMTP credentials
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=<your-brevo-email>
SMTP_PASS=<your-brevo-smtp-password>
FROM_EMAIL=noreply@standor.dev

# ---- Redis / Upstash (Socket.IO adapter — free tier) ----
# upstash.com → Create Redis database → REST URL
REDIS_URL=<your-upstash-redis-url>

# ---- Next.js public vars (prefix NEXT_PUBLIC_) ----
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=<same-as-GOOGLE_CLIENT_ID>
