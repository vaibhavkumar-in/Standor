# ============================================================
# Standor Backend — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=5001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB (Free: MongoDB Atlas free tier)
# Get at: mongodb.com/cloud/atlas → Create free cluster
DB_URL=<your-mongodb-atlas-connection-string>

# JWT Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-random-64-char-secret-key

# Google OAuth (Free)
# Steps: console.cloud.google.com → New Project → APIs & Services
#   → Credentials → Create OAuth 2.0 Client ID
#   → Set authorized redirect URIs: http://localhost:5001
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (Free: Brevo SMTP — 300 emails/day free)
# Get at: brevo.com → Create account → SMTP & API → Generate SMTP password
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login-email
SMTP_PASS=your-brevo-smtp-password
FROM_EMAIL=noreply@standor.dev

# AI Analysis (Free: OpenRouter with DeepSeek Coder)
# Get at: openrouter.ai → Create account → API Keys
# Free credits available on sign-up
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Code Execution (Free: Piston public API — no key needed)
PISTON_API_URL=https://emkc.org/api/v2/piston
